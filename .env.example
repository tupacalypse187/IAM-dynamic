# ============================================
# AI Provider Configuration
# ============================================
# Choose your LLM provider: gemini, openai, anthropic/claude, or zhipu/glm
LLM_PROVIDER=gemini

# --- Gemini Configuration (Google) ---
# Gemini 3 Pro Preview (released November 2025)
GOOGLE_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-3-pro-preview
# Alternative: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.5-pro

# --- OpenAI Configuration ---
# GPT-5.2 (latest) - GPT-5.1 and GPT-5 are previous models
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.2
# Alternatives: gpt-5.1, gpt-5, o3-pro (reasoning), gpt-4o, gpt-4o-mini

# --- Anthropic Claude Configuration ---
# Claude Opus 4.5 (released November 24, 2025) - latest flagship
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-5-20251101
# Alternatives: claude-sonnet-4-5-20251022, claude-haiku-4-5-20250214

# --- Zhipu GLM Configuration ---
# GLM-4.7 (December 2025) - latest flagship
# ZHIPUAI_API_KEY=...
# ZHIPUAI_MODEL=glm-4.7
# Alternative: glm-4.7-flash (lightweight version)

# ============================================
# AWS Configuration
# ============================================
AWS_ACCOUNT_ID=123456789012
AWS_ROLE_NAME=AgentPOCSessionRole  # Role to be assumed by the app

# ============================================
# Slack Integration (Optional)
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Approval Configuration
# ============================================
APPROVER_NAME=Admin

# ============================================
# Database Configuration
# ============================================
DATABASE_PATH=iam_dynamic.db
